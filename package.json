{
  "name": "c2c-mcp",
  "version": "1.0.0",
  "description": "LAN-based collaboration for Claude Code instances via MCP — share intent, file changes, and async messages between peers",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "c2c": "dist/cli.js"
  },
  "files": [
    "dist",
    "skill"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "pnpm build",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": ["mcp", "claude-code", "collaboration", "lan", "peer-to-peer"],
  "author": "CLCK0622",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CLCK0622/c2c-mcp.git"
  },
  "packageManager": "pnpm@10.28.2",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "bonjour-service": "^1.3.0",
    "chokidar": "^5.0.0",
    "uuid": "^14.0.0",
    "ws": "^8.20.0",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/uuid": "^11.0.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
